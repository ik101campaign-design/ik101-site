---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
---
<Layout title="Artists! Let Your Art Be the Voice for Change | IK101">
  <SiteNav current="/artist" />

  <main class="art-main">

    <!-- HERO -->
    <section class="art-hero">
      <p class="art-eyebrow">Artist</p>
      <h1 class="art-h1">Let your art be the voice for change!</h1>
      <p class="art-lede">Your canvases are calling for change! Contribute traditional artwork or digital projects to the #IK101 movement and be part of the visual revolution. Your art will be featured across multiple platforms including global postcards, the Truth To Power Hub, social media, etc. for spreading messages of democracy, civic education and human rights.</p>
      <div class="art-ctas">
        <a class="art-cta-primary" href="https://forms.gle/R2jqcER5ghT8vnTs5" target="_blank" rel="noopener">Submit Artwork</a>
        <a class="art-cta-secondary" href="https://drive.google.com/drive/u/0/folders/1aK4u7ohzy-2qYrll0n39q-cKwwpFnqmj" target="_blank" rel="noopener">Themes for Artwork</a>
        <a class="art-cta-secondary" href="#artistcall">Artist Call</a>
      </div>
    </section>

    <!-- ARTIST CALL -->
    <section class="art-section" id="artistcall">
      <h2 class="art-section-heading">Artist Call</h2>
      <div class="art-call-images">
        <figure class="art-call-fig">
          <img src="/artist/themes-for-artwork-Y4L4M2w5x0IJZq9W.png" alt="Themes for IK101 Artwork" loading="lazy" />
        </figure>
        <figure class="art-call-fig">
          <img src="/artist/ik101-artist-call-mjE2XxoN7Rs1ZwqE.png" alt="IK101 Artist Call Poster" loading="lazy" />
        </figure>
      </div>
      <a class="art-link-out" href="https://drive.google.com/drive/u/0/folders/1qpAxa80_9z03Q6vyzGRJFWO4qHtNtT24" target="_blank" rel="noopener">View the full call ↗</a>
    </section>

    <!-- IK101 ARTISTS -->
    <section class="art-section">
      <h2 class="art-section-heading">IK101 Artists</h2>
      <div class="art-gallery">
        <figure class="art-tile">
          <img src="/artist/ik101-light-eng-AMqn9w6EV3Ho6vL6.png" alt="IK101 Light — English artwork" loading="lazy" />
        </figure>
        <figure class="art-tile">
          <img src="/artist/ik101-unplugged-eng-YbNazXkLB3CMXzn7.png" alt="IK101 Unplugged — English artwork" loading="lazy" />
        </figure>
        <figure class="art-tile">
          <img src="/artist/art-for-postcard-eng-mk3DQxo69Xt1vrgv.png" alt="Art for Postcard — English" loading="lazy" />
        </figure>
        <figure class="art-tile">
          <img src="/artist/art-for-postcard-urdu-YKbJXvnj3xfGR3RW.png" alt="Art for Postcard — Urdu" loading="lazy" />
        </figure>
        <figure class="art-tile">
          <img src="/artist/sos-capt.-gulsher-eng-m7VpeZPvDpUpV2Xl.png" alt="SOS Captain Gulsher — English" loading="lazy" />
        </figure>
        <figure class="art-tile">
          <img src="/artist/sos-capt.-gulsher-urdu-dWxl19o2l1ueW3nE.png" alt="SOS Captain Gulsher — Urdu" loading="lazy" />
        </figure>
      </div>
      <a class="art-link-out" href="https://drive.google.com/drive/u/0/folders/1qpAxa80_9z03Q6vyzGRJFWO4qHtNtT24" target="_blank" rel="noopener">Browse the gallery ↗</a>
    </section>

    <!-- FEATURED ARTISTS -->
    <section class="art-section">
      <h2 class="art-section-heading">Featured Artists</h2>
      <div class="art-quotes">

        <article class="art-quote-card">
          <blockquote class="art-quote-text">"My artwork celebrates Pakistan's diversity and the unwavering spirit of a leader who inspires us to strive for a better future."</blockquote>
          <p class="art-quote-attr">— <a href="https://youtube.com/shorts/vYv_YFTSEF4?feature=share" target="_blank" rel="noopener" class="art-artist-link">Javeria Khan</a></p>
        </article>

        <article class="art-quote-card">
          <blockquote class="art-quote-text">"My work for IK101 aims to tell a visual story, educating viewers about the impact within the local and global community."</blockquote>
          <p class="art-quote-attr">— <a href="https://youtube.com/shorts/fxqK9pN5kts?feature=share" target="_blank" rel="noopener" class="art-artist-link">Alfiyah Safdar Ali</a></p>
        </article>

        <article class="art-quote-card">
          <blockquote class="art-quote-text">"Dedicated to the intersection of art and Imran Khan, I embarked on a unique artistic journey, driven by my passion for illustration."</blockquote>
          <p class="art-quote-attr">— <a href="https://youtube.com/shorts/N4qr1rBs884?feature=share" target="_blank" rel="noopener" class="art-artist-link">Nimra</a></p>
        </article>

        <article class="art-quote-card">
          <blockquote class="art-quote-text">"I capture Imran Khan's journey and portray his struggle through graphics and videos to inspire people to play an active part for change."</blockquote>
          <p class="art-quote-attr">— <span class="art-artist-plain">Hanii Tales</span></p>
        </article>

        <article class="art-quote-card">
          <blockquote class="art-quote-text">"My IK101 art sees the Trango Towers of Gilgit-Baltistan as a metaphor for Pakistan's great potential under the leadership of Imran Khan."</blockquote>
          <p class="art-quote-attr">— <a href="https://youtube.com/shorts/K0gf0hHrPRE?feature=share" target="_blank" rel="noopener" class="art-artist-link">Nayma Yasir</a></p>
        </article>

        <article class="art-quote-card">
          <blockquote class="art-quote-text">"My art for IK101 is a narrative of inspiration and a tribute to the deep-seated connection Imran Khan shares with the people of Pakistan."</blockquote>
          <p class="art-quote-attr">— <a href="https://youtube.com/shorts/8IBgoaisZuY?feature=share" target="_blank" rel="noopener" class="art-artist-link">Sameeya Zafar</a></p>
        </article>

      </div>
    </section>

    <!-- CLOSE STATEMENT -->
    <section class="art-close">
      <p class="art-statement">My Voice, My Pakistan, My Movement.</p>
    </section>

  </main>

  <footer class="art-foot">
    <nav class="art-foot-links">
      <a href="/">Resources</a><a href="/">Connect</a><a href="/">Useful Links</a>
    </nav>
    <p class="art-foot-copy">IK101 © 2023</p>
  </footer>

  <style is:global>
    /* ── Artist page ─────────────────────────────────────────────── */
    .art-main {
      max-width: 1200px;
      margin: 0 auto;
      padding: clamp(1rem, 3vw, 2.5rem) 1.25rem 2rem;
    }

    /* HERO */
    .art-hero {
      text-align: center;
      max-width: 62ch;
      margin: 0 auto clamp(3rem, 8vw, 6rem);
      padding-top: clamp(1rem, 3vw, 2rem);
    }
    .art-eyebrow {
      color: var(--accent);
      font-weight: 600;
      letter-spacing: .14em;
      text-transform: uppercase;
      font-size: .8rem;
      margin: 0 0 1rem;
    }
    .art-h1 {
      font-size: clamp(2rem, 4.6vw, 3.4rem);
      line-height: 1.06;
      letter-spacing: -.025em;
      font-weight: 700;
      margin: 0 auto 1.1rem;
      max-width: 22ch;
    }
    .art-lede {
      color: var(--muted);
      font-size: 1.05rem;
      line-height: 1.65;
      margin: 0 auto 2rem;
      max-width: 62ch;
    }
    .art-ctas {
      display: flex;
      flex-wrap: wrap;
      gap: .75rem;
      justify-content: center;
    }
    .art-cta-primary {
      display: inline-block;
      background: var(--accent);
      color: var(--ink);
      font-weight: 600;
      font-size: .95rem;
      text-decoration: none;
      padding: .85rem 1.8rem;
      border-radius: 100px;
      transition: transform .2s var(--ease-out), filter .2s;
    }
    .art-cta-primary:hover {
      transform: translateY(-1px);
      filter: brightness(1.05);
    }
    .art-cta-secondary {
      display: inline-block;
      background: transparent;
      color: var(--ink);
      font-weight: 600;
      font-size: .95rem;
      text-decoration: none;
      padding: .82rem 1.75rem;
      border-radius: 100px;
      border: 1.5px solid var(--ink);
      transition: border-color .2s var(--ease-out), color .2s, transform .2s var(--ease-out);
    }
    .art-cta-secondary:hover {
      border-color: var(--accent);
      color: var(--accent);
      transform: translateY(-1px);
    }

    /* SECTIONS */
    .art-section {
      margin-bottom: clamp(3rem, 8vw, 6rem);
      text-align: center;
    }
    .art-section-heading {
      font-size: clamp(1.5rem, 3.2vw, 2.2rem);
      font-weight: 700;
      letter-spacing: -.02em;
      margin: 0 0 clamp(1.5rem, 4vw, 2.5rem);
    }
    .art-link-out {
      display: inline-block;
      margin-top: clamp(1.25rem, 3vw, 2rem);
      color: var(--accent);
      font-weight: 600;
      font-size: .9rem;
      text-decoration: none;
      transition: opacity .2s;
    }
    .art-link-out:hover {
      opacity: .75;
    }

    /* ARTIST CALL — two images side by side */
    .art-call-images {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: clamp(1rem, 2.5vw, 2rem);
      max-width: 860px;
      margin: 0 auto;
    }
    .art-call-fig {
      margin: 0;
      border-radius: 16px;
      overflow: hidden;
      border: 1px solid var(--faint);
      background: #fafbfa;
    }
    .art-call-fig img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform .4s var(--ease-out);
    }
    .art-call-fig:hover img {
      transform: scale(1.03);
    }

    /* ARTWORK GALLERY — 3-col grid */
    .art-gallery {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: clamp(.75rem, 2vw, 1.5rem);
    }
    .art-tile {
      margin: 0;
      border-radius: 16px;
      overflow: hidden;
      border: 1px solid var(--faint);
      background: #fafbfa;
      aspect-ratio: 1 / 1;
      transition: transform .3s var(--ease-out), box-shadow .3s var(--ease-out);
    }
    .art-tile:hover {
      transform: translateY(-4px);
      box-shadow: 0 16px 40px rgba(20,40,28,.14);
    }
    .art-tile img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    /* FEATURED ARTIST QUOTE CARDS */
    .art-quotes {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: clamp(1rem, 2vw, 1.5rem);
      text-align: left;
    }
    .art-quote-card {
      background: #fff;
      border: 1px solid var(--faint);
      border-radius: 16px;
      padding: clamp(1.25rem, 2.5vw, 2rem);
      display: flex;
      flex-direction: column;
      gap: 1rem;
      transition: box-shadow .25s var(--ease-out), transform .25s var(--ease-out);
    }
    .art-quote-card:hover {
      box-shadow: 0 8px 28px rgba(20,40,28,.1);
      transform: translateY(-2px);
    }
    .art-quote-text {
      font-size: 1.02rem;
      line-height: 1.65;
      color: var(--ink);
      font-style: italic;
      margin: 0;
      flex: 1;
      quotes: "\201C" "\201D";
    }
    .art-quote-attr {
      margin: 0;
      font-size: .88rem;
      font-weight: 600;
      color: var(--muted);
    }
    .art-artist-link {
      color: var(--accent);
      text-decoration: none;
      transition: opacity .2s;
    }
    .art-artist-link:hover {
      opacity: .75;
    }
    .art-artist-plain {
      color: var(--ink);
    }

    /* CLOSE STATEMENT */
    .art-close {
      text-align: center;
      margin-top: clamp(3rem, 8vw, 6rem);
    }
    .art-statement {
      font-size: clamp(1.6rem, 4vw, 2.6rem);
      font-weight: 700;
      letter-spacing: -.02em;
      margin: 0;
    }

    /* FOOTER */
    .art-foot {
      border-top: 1px solid var(--faint);
      margin-top: clamp(3rem, 8vw, 6rem);
      padding: 3rem 1.25rem;
      text-align: center;
    }
    .art-foot-links {
      display: flex;
      gap: 2rem;
      justify-content: center;
      margin-bottom: 1.5rem;
    }
    .art-foot-links a {
      color: var(--muted);
      text-decoration: none;
      font-size: .9rem;
    }
    .art-foot-links a:hover {
      color: var(--ink);
    }
    .art-foot-copy {
      color: var(--muted);
      font-size: .8rem;
      margin: 0;
    }

    /* RESPONSIVE */
    @media (max-width: 860px) {
      .art-quotes {
        grid-template-columns: repeat(2, 1fr);
      }
      .art-gallery {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    @media (max-width: 560px) {
      .art-call-images {
        grid-template-columns: 1fr;
      }
      .art-gallery {
        grid-template-columns: repeat(2, 1fr);
      }
      .art-quotes {
        grid-template-columns: 1fr;
      }
    }
    @media (prefers-reduced-motion: reduce) {
      .art-tile, .art-call-fig img, .art-quote-card { transition: none; }
    }
  </style>
</Layout>
