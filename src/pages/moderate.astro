---
import Layout from '../layouts/Layout.astro';
---
<Layout title="IK101 — Moderate">
  <main class="mod-main">
    <h1 class="mod-heading">Moderate voices</h1>
    <section data-auth-gate class="mod-card">
      <p class="mod-intro">Sign in with the campaign's GitHub account to review submissions.</p>
      <button data-login-github type="button" class="mod-btn-primary">Sign in with GitHub</button>
      <p data-login-error role="alert" class="mod-error"></p>
    </section>
    <section data-queue hidden></section>
  </main>
  <script>
    import('../components/moderate/queue.ts').then((m) => m.mountModerate());
  </script>
</Layout>

<style>
  .mod-main { max-width: 640px; margin: 4rem auto; padding: 1rem; }
  .mod-heading { font-family: var(--font-sans); font-size: 1.75rem; font-weight: 700; color: var(--ink); letter-spacing: -0.02em; margin: 0 0 2rem; }
  .mod-card { max-width: 420px; margin: 0 auto; background: #ffffff; border: 1px solid rgba(20, 40, 28, 0.08); border-radius: 20px; padding: 28px 26px 24px; box-shadow: 0 4px 24px rgba(20, 40, 28, 0.07); display: flex; flex-direction: column; gap: 14px; font-family: var(--font-sans); }
  .mod-intro { margin: 0; font-size: 0.95rem; color: var(--muted); }
  .mod-btn-primary { background: var(--accent); color: var(--ink); border: none; border-radius: 100px; padding: 11px 22px; font-size: 0.9rem; font-weight: 600; font-family: inherit; cursor: pointer; transition: filter 0.15s, transform 0.15s; align-self: flex-start; }
  .mod-btn-primary:hover { filter: brightness(1.05); transform: translateY(-1px); }
  .mod-error { font-size: 0.85rem; color: #b03030; margin: 0; min-height: 1.2em; }
</style>
