---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
---
<Layout title="IK101 — Dansk">
  <SiteNav current="/danish" />

  <main class="lng-da-main" lang="da">

    <!-- HERO -->
    <section class="lng-da-hero">
      <p class="lng-da-eyebrow">IK101 &mdash; Dansk</p>
      <h1 class="lng-da-h1">Fra Imran Khans liv som rollemodel til din handling</h1>
      <p class="lng-da-lede">IK101 er et borgerinitiativ, der hylder Imran Khans søgen efter et stærkere, forenet Pakistan og inviterer &ldquo;101 Sparks of Progress&rdquo; til at genopbygge kollektivt.</p>
      <div class="lng-da-hero-ctas">
        <a class="lng-da-btn lng-da-btn--primary" href="https://drive.google.com/drive/folders/1U-Hio0z8I7dBizlwHgXtVcZM2jLeFCjj" target="_blank" rel="noopener">Postkort</a>
        <a class="lng-da-btn lng-da-btn--outline" href="https://drive.google.com/drive/folders/1DI89clL2RyHBQMP-ttzPDIMkVv0PATh8" target="_blank" rel="noopener">Andragender</a>
        <a class="lng-da-btn lng-da-btn--outline" href="https://drive.google.com/drive/folders/19sCV_szcgj98W98Kk7HI9XcjgLPikGLR" target="_blank" rel="noopener">Flyers</a>
        <a class="lng-da-btn lng-da-btn--ghost" href="https://drive.google.com/drive/folders/1SG9XBBLVZOWCMpA94GON1lXJLjZhDtup" target="_blank" rel="noopener">AI til IK101</a>
      </div>
    </section>

    <!-- 101 SPARKS BANNER -->
    <section class="lng-da-sparks">
      <div class="lng-da-sparks-img-wrap">
        <img class="lng-da-sparks-img" src="/danish/101-sparks-YBgpvoDK8eHBqnVr.png" alt="101 Gnister til et progressivt Pakistan" loading="lazy" />
      </div>
      <div class="lng-da-sparks-body">
        <h4 class="lng-da-sparks-h">101 gnister til et progressivt Pakistan</h4>
        <p class="lng-da-sparks-p">IK101 er et borgerinitiativ, der hylder Imran Khans søgen efter et stærkere, forenet Pakistan og inviterer &ldquo;101 Sparks of Progress&rdquo; til at genopbygge kollektivt.</p>
      </div>
    </section>

    <!-- SPIRIT OF IK101 -->
    <section class="lng-da-spirit">
      <p class="lng-da-eyebrow">Spirit of IK101</p>
      <h4 class="lng-da-spirit-h">Spirit of IK101</h4>
      <p class="lng-da-spirit-p">I hjertet af IK101 genlyder den varige arv fra Imran Khan, et liv dedikeret til jagten på en velfærdsstat, hvor ethvert individs rettigheder ikke blot anerkendes, men stærkt beskyttes. IK101 er en opfordring til at forstærke din stemme, skabe forbindelse til borgere globalt og bidrage til at opbygge et ægte uafhængigt, demokratisk og progressivt Pakistan.</p>
      <p class="lng-da-spirit-p">Du behøver ikke at være ét sted for at være en del af IK101. Hop ind i handlingen fra græsrodsengagement til den dynamiske fase af IK101 Engage, en platform, hvor dine ideer til fremskridt tager liv. Berig vores digitale galleri, del dine fortællinger og inspirationer, og lad os fremvise kraften i kollektive stemmer. Deltag i bevægelsen!</p>
      <div class="lng-da-spirit-jump">
        <a class="lng-da-jump-link" href="#da-artist">Kunstner</a>
        <a class="lng-da-jump-link" href="#da-ambassador">Ambassadør</a>
        <a class="lng-da-jump-link" href="#da-volunteer">Frivillig</a>
      </div>
    </section>

    <!-- AMBASSADOR SECTION -->
    <section class="lng-da-section" id="da-ambassador">
      <p class="lng-da-eyebrow">Ambassadør</p>
      <h4 class="lng-da-section-h">Tag med os på en rejse med græsrodsaktivisme</h4>

      <!-- Grassroots / Amplify row -->
      <div class="lng-da-row">
        <div class="lng-da-row__img-wrap">
          <img class="lng-da-row__img" src="/danish/slider-grassroots-activation-mjE2XLjVQ3u5G0jB.png" alt="Græsrodsaktivisme" loading="lazy" />
        </div>
        <div class="lng-da-row__body">
          <h6 class="lng-da-row__sub">Forstærk IK101-stemmer</h6>
          <p class="lng-da-row__text">Bliv #IK101-ambassadør i aktion, gå fra dør til dør, spred budskabet om positivt lederskab og forandring. Hvert skridt, hver samtale betyder noget. Dit engagement former fortællingen, og sammen bygger vi et robust, forenet Pakistan.</p>
          <p class="lng-da-row__text">IK101-bevægelsen trives med kollektive stemmer. Deltag i handlingen og fremdriv positive forandringer. Udforsk og download fællesskabsbidragede videoer og billeder fra vores digitale galleri. Tag #IK101 og del disse magthistorier på dine sociale kanaler.</p>
          <a class="lng-da-cta" href="https://drive.google.com/drive/folders/1a2c0ytJWwS6TrfBuLLfH1DeQUCcRBFio" target="_blank" rel="noopener">Digital Gallery &#8594;</a>
        </div>
      </div>

      <!-- Petition row (flipped) -->
      <div class="lng-da-row lng-da-row--flip">
        <div class="lng-da-row__img-wrap">
          <img class="lng-da-row__img" src="/danish/slider-sign-a-petition-d95pBENBXPU7JRln.png" alt="Underskriv et andragende" loading="lazy" />
        </div>
        <div class="lng-da-row__body">
          <h6 class="lng-da-row__sub">Underskriv et andragende</h6>
          <p class="lng-da-row__text">Udnyt kraften i din indflydelse til at gå ind for demokrati i Pakistan, kræve en ende på fascismen mod verdens sjettestørste politiske parti, og protester mod den ulovlige tilbageholdelse af Imran Khan, Pakistans mest populære leder. Download skabelonerne; tilføj din indsigt, del din appel med lokale politiske repræsentanter, ambassadører og indflydelsesrige personer.</p>
          <a class="lng-da-cta" href="https://drive.google.com/drive/folders/1DI89clL2RyHBQMP-ttzPDIMkVv0PATh8" target="_blank" rel="noopener">Andragender &#8594;</a>
        </div>
      </div>

      <!-- Postcard row -->
      <div class="lng-da-row">
        <div class="lng-da-row__img-wrap">
          <img class="lng-da-row__img" src="/danish/slider-mail-a-postcard-AwvrBL0ov7I2z6Bk.png" alt="Send et postkort" loading="lazy" />
        </div>
        <div class="lng-da-row__body">
          <h6 class="lng-da-row__sub">Send et postkort</h6>
          <p class="lng-da-row__text">Klar til at gøre en forskel? Slut dig til IK101-bevægelsen med et dynamisk postkort for at sætte gang i samtalen om positiv forandring. Download og udskriv skabelon efter eget valg, på et sprog efter eget valg, fremhæv Imran Khans mest indflydelsesrige præstation, der giver genlyd hos dig, fremvis din unikke idé til fremskridt og send postkortet til en community influencer.</p>
          <a class="lng-da-cta" href="https://drive.google.com/drive/folders/1U-Hio0z8I7dBizlwHgXtVcZM2jLeFCjj" target="_blank" rel="noopener">Postkort &#8594;</a>
        </div>
      </div>

    </section>

    <!-- ARTIST SECTION -->
    <section class="lng-da-section" id="da-artist">
      <p class="lng-da-eyebrow">Kunstner</p>
      <h4 class="lng-da-section-h">Lad din kunst være stemmen for forandring!</h4>
      <div class="lng-da-row">
        <div class="lng-da-row__img-wrap">
          <img class="lng-da-row__img" src="/danish/ik101-artist-call-mjE2XxoN7Rs1ZwqE.png" alt="IK101 Kunstner" loading="lazy" />
        </div>
        <div class="lng-da-row__body">
          <p class="lng-da-row__text">Dine lærreder kalder på forandring! Bidrag traditionelt kunstværker eller digitale projekter til #IK101-bevægelsen og være del af den visuelle revolution. Din kunst vil blive vist på tværs flere platforme inklusive globale postkort, Truth To Power Hub, sociale medier osv. til spredning af budskaber af demokrati, medborgeruddannelse og menneskerettigheder.</p>
          <div class="lng-da-cta-group">
            <a class="lng-da-cta" href="https://drive.google.com/drive/folders/1qpAxa80_9z03Q6vyzGRJFWO4qHtNtT24" target="_blank" rel="noopener">Artist Call &#8594;</a>
            <a class="lng-da-cta lng-da-cta--ghost" href="https://docs.google.com/forms/d/e/1FAIpQLScp3ky9BpBUM6DvEQssAeDiVJEvlNFmRbzeR8mxSSFng5_4yQ/viewform" target="_blank" rel="noopener">Submit Artwork &#8594;</a>
            <a class="lng-da-cta lng-da-cta--ghost" href="https://drive.google.com/drive/folders/1aK4u7ohzy-2qYrll0n39q-cKwwpFnqmj" target="_blank" rel="noopener">Themes for Artwork &#8594;</a>
          </div>
        </div>
      </div>
    </section>

    <!-- VOLUNTEER SECTION -->
    <section class="lng-da-section" id="da-volunteer">
      <p class="lng-da-eyebrow">Frivillig</p>
      <div class="lng-da-vol-card">
        <div class="lng-da-vol-body">
          <h4 class="lng-da-vol-h">Klar til at gøre en forskel? Sæt dine evner i arbejde</h4>
          <p class="lng-da-vol-p">Bliv frivillig inden for dit fagområde. Send os en mail, så vi kan koordinere dit bidrag. Fremhæv dine færdigheder: oversættelse, undertekstning, korrekturlæsning, lokalsamfund aktivering, digital annoncering, grafisk &amp; videodesign, social mediemarkedsføring, research, blogskrivning, print og fordeling.</p>
          <a class="lng-da-btn lng-da-btn--primary" href="https://docs.google.com/forms/d/e/1FAIpQLSdOwDOVHxvIIrH_HKSXcstQbiW_ibtkKkk_5q-zt2is7H1ulQ/viewform" target="_blank" rel="noopener">Volunteer Registration Form</a>
        </div>
        <div class="lng-da-vol-img-wrap">
          <img class="lng-da-vol-img" src="/danish/ik101-student---1-d95pL2wNZBTvbDQo.png" alt="IK101 Frivillig" loading="lazy" />
        </div>
      </div>
    </section>

    <!-- CLOSING -->
    <section class="lng-da-close">
      <h5 class="lng-da-close-sub">Lad os forene vores stemmer for at bygge et ægte demokratisk Pakistan.</h5>
      <h3 class="lng-da-close-h">My Voice, My Pakistan, My Movement.</h3>
    </section>

  </main>

  <footer class="lng-da-foot">
    <nav class="lng-da-foot-links">
      <a href="/#resources">Resources</a>
      <a href="/connect">Connect</a>
      <a href="/useful-links">Useful Links</a>
    </nav>
    <p class="lng-da-foot-copy">IK101 &copy; 2023</p>
  </footer>

  <style is:global>
    /* ── Danish landing page — all classes prefixed .lng-da- ── */

    .lng-da-main {
      max-width: 1200px;
      margin: 0 auto;
      padding: clamp(2rem, 5vw, 4rem) 1.25rem 2rem;
    }

    /* ── SHARED EYEBROW ── */
    .lng-da-eyebrow {
      color: var(--accent);
      font-weight: 600;
      letter-spacing: .14em;
      text-transform: uppercase;
      font-size: .78rem;
      margin: 0 0 .9rem;
    }

    /* ── HERO ── */
    .lng-da-hero {
      text-align: center;
      max-width: 64ch;
      margin: 0 auto clamp(3.5rem, 8vw, 6rem);
    }
    .lng-da-h1 {
      font-size: clamp(2rem, 4.6vw, 3.4rem);
      line-height: 1.06;
      letter-spacing: -.025em;
      font-weight: 700;
      margin: 0 auto 1.1rem;
      max-width: 22ch;
    }
    .lng-da-lede {
      color: var(--muted);
      font-size: 1.05rem;
      line-height: 1.65;
      max-width: 60ch;
      margin: 0 auto 2.2rem;
    }
    .lng-da-hero-ctas {
      display: flex;
      flex-wrap: wrap;
      gap: .8rem;
      justify-content: center;
    }

    /* ── BUTTONS ── */
    .lng-da-btn {
      display: inline-block;
      font-weight: 600;
      font-size: .93rem;
      text-decoration: none;
      padding: .82rem 1.75rem;
      border-radius: 100px;
      transition: transform .2s var(--ease-out), filter .2s, background .2s, color .2s;
    }
    .lng-da-btn:hover {
      transform: translateY(-1px);
    }
    .lng-da-btn--primary {
      background: var(--accent);
      color: var(--ink);
    }
    .lng-da-btn--primary:hover {
      filter: brightness(1.06);
    }
    .lng-da-btn--outline {
      background: transparent;
      color: var(--ink);
      border: 1.5px solid var(--ink);
    }
    .lng-da-btn--outline:hover {
      background: var(--faint);
    }
    .lng-da-btn--ghost {
      background: transparent;
      color: var(--muted);
      border: 1.5px solid var(--faint);
    }
    .lng-da-btn--ghost:hover {
      border-color: var(--accent);
      color: var(--accent);
    }

    /* ── 101 SPARKS BANNER ── */
    .lng-da-sparks {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: clamp(2rem, 5vw, 4rem);
      align-items: center;
      background: var(--faint);
      border-radius: 16px;
      overflow: hidden;
      margin-bottom: clamp(3.5rem, 9vw, 7rem);
    }
    .lng-da-sparks-img-wrap {
      aspect-ratio: 4 / 3;
      overflow: hidden;
    }
    .lng-da-sparks-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .lng-da-sparks-body {
      padding: clamp(1.5rem, 3vw, 2.5rem) clamp(1.5rem, 3vw, 2.5rem) clamp(1.5rem, 3vw, 2.5rem) 0;
    }
    .lng-da-sparks-h {
      font-size: clamp(1.4rem, 2.6vw, 2rem);
      font-weight: 700;
      letter-spacing: -.02em;
      line-height: 1.15;
      margin: 0 0 1rem;
    }
    .lng-da-sparks-p {
      color: var(--muted);
      font-size: 1rem;
      line-height: 1.65;
      margin: 0;
    }

    /* ── SPIRIT SECTION ── */
    .lng-da-spirit {
      text-align: center;
      max-width: 70ch;
      margin: 0 auto clamp(3.5rem, 9vw, 7rem);
    }
    .lng-da-spirit-h {
      font-size: clamp(1.5rem, 3.2vw, 2.2rem);
      font-weight: 700;
      letter-spacing: -.02em;
      margin: 0 0 1.2rem;
    }
    .lng-da-spirit-p {
      color: var(--muted);
      font-size: 1.02rem;
      line-height: 1.7;
      margin: 0 0 1.1rem;
    }
    .lng-da-spirit-jump {
      display: flex;
      flex-wrap: wrap;
      gap: .9rem;
      justify-content: center;
      margin-top: 2rem;
    }
    .lng-da-jump-link {
      display: inline-block;
      color: var(--accent);
      font-weight: 600;
      font-size: .9rem;
      text-decoration: none;
      padding: .6rem 1.4rem;
      border: 1.5px solid var(--accent);
      border-radius: 100px;
      transition: background .2s var(--ease-out), color .2s;
    }
    .lng-da-jump-link:hover {
      background: var(--accent);
      color: var(--ink);
    }

    /* ── CONTENT SECTIONS ── */
    .lng-da-section {
      margin-bottom: clamp(4rem, 10vw, 8rem);
    }
    .lng-da-section-h {
      font-size: clamp(1.6rem, 3.4vw, 2.4rem);
      font-weight: 700;
      letter-spacing: -.022em;
      line-height: 1.1;
      margin: 0 0 clamp(2rem, 5vw, 4rem);
      max-width: 28ch;
    }

    /* ── FEATURE ROWS ── */
    .lng-da-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: clamp(2rem, 5vw, 4.5rem);
      align-items: center;
      margin-bottom: clamp(3rem, 7vw, 5.5rem);
    }
    .lng-da-row--flip {
      direction: rtl;
    }
    .lng-da-row--flip > * {
      direction: ltr;
    }
    .lng-da-row__img-wrap {
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 20px 56px rgba(20,40,28,.13);
      aspect-ratio: 4 / 3;
      background: #f1f5f2;
    }
    .lng-da-row__img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .lng-da-row__body {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .lng-da-row__sub {
      color: var(--accent);
      font-weight: 600;
      letter-spacing: .1em;
      text-transform: uppercase;
      font-size: .78rem;
      margin: 0;
    }
    .lng-da-row__text {
      color: var(--muted);
      font-size: 1rem;
      line-height: 1.65;
      margin: 0;
    }
    .lng-da-cta {
      display: inline-block;
      color: var(--accent);
      font-weight: 600;
      font-size: .93rem;
      text-decoration: none;
      padding: .7rem 1.5rem;
      border: 1.5px solid var(--accent);
      border-radius: 100px;
      align-self: flex-start;
      transition: background .2s var(--ease-out), color .2s, transform .2s var(--ease-out);
    }
    .lng-da-cta:hover {
      background: var(--accent);
      color: var(--ink);
      transform: translateY(-1px);
    }
    .lng-da-cta--ghost {
      color: var(--muted);
      border-color: var(--faint);
    }
    .lng-da-cta--ghost:hover {
      border-color: var(--accent);
      color: var(--ink);
      background: var(--accent);
    }
    .lng-da-cta-group {
      display: flex;
      flex-wrap: wrap;
      gap: .75rem;
    }

    /* ── VOLUNTEER CARD ── */
    .lng-da-vol-card {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: clamp(2rem, 5vw, 4rem);
      align-items: center;
      background: var(--faint);
      border-radius: 16px;
      overflow: hidden;
      border: 1px solid var(--faint);
    }
    .lng-da-vol-body {
      padding: clamp(2rem, 4vw, 3.5rem) clamp(1.5rem, 3vw, 2.5rem) clamp(2rem, 4vw, 3.5rem) clamp(1.5rem, 3vw, 2.5rem);
      display: flex;
      flex-direction: column;
      gap: 1.2rem;
    }
    .lng-da-vol-h {
      font-size: clamp(1.4rem, 2.6vw, 2rem);
      font-weight: 700;
      letter-spacing: -.02em;
      line-height: 1.15;
      margin: 0;
    }
    .lng-da-vol-p {
      color: var(--muted);
      font-size: 1rem;
      line-height: 1.65;
      margin: 0;
    }
    .lng-da-vol-img-wrap {
      aspect-ratio: 4 / 3;
      overflow: hidden;
    }
    .lng-da-vol-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    /* ── CLOSING ── */
    .lng-da-close {
      text-align: center;
      padding: clamp(3rem, 8vw, 6rem) 0 clamp(2rem, 5vw, 4rem);
    }
    .lng-da-close-sub {
      color: var(--muted);
      font-size: clamp(1rem, 1.8vw, 1.2rem);
      font-weight: 400;
      line-height: 1.6;
      max-width: 52ch;
      margin: 0 auto 1.5rem;
    }
    .lng-da-close-h {
      font-size: clamp(1.8rem, 4.2vw, 3rem);
      font-weight: 700;
      letter-spacing: -.025em;
      margin: 0;
    }

    /* ── FOOTER ── */
    .lng-da-foot {
      border-top: 1px solid var(--faint);
      margin-top: clamp(2rem, 5vw, 4rem);
      padding: 3rem 1.25rem;
      text-align: center;
    }
    .lng-da-foot-links {
      display: flex;
      gap: 2rem;
      justify-content: center;
      margin-bottom: 1.5rem;
    }
    .lng-da-foot-links a {
      color: var(--muted);
      text-decoration: none;
      font-size: .9rem;
      transition: color .2s;
    }
    .lng-da-foot-links a:hover {
      color: var(--ink);
    }
    .lng-da-foot-copy {
      color: var(--muted);
      font-size: .8rem;
      margin: 0;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 860px) {
      .lng-da-sparks {
        grid-template-columns: 1fr;
      }
      .lng-da-sparks-body {
        padding: clamp(1.5rem, 3vw, 2.5rem);
      }
      .lng-da-vol-card {
        grid-template-columns: 1fr;
      }
      .lng-da-vol-img-wrap {
        order: -1;
        aspect-ratio: 16 / 9;
      }
    }
    @media (max-width: 720px) {
      .lng-da-row,
      .lng-da-row--flip {
        grid-template-columns: 1fr;
        direction: ltr;
      }
      .lng-da-row--flip > * {
        direction: ltr;
      }
      .lng-da-row__img-wrap {
        aspect-ratio: 16 / 10;
      }
      .lng-da-cta {
        align-self: stretch;
        text-align: center;
      }
      .lng-da-cta-group {
        flex-direction: column;
      }
    }
    @media (max-width: 500px) {
      .lng-da-hero-ctas {
        flex-direction: column;
      }
      .lng-da-btn {
        width: 100%;
        text-align: center;
      }
      .lng-da-foot-links {
        flex-direction: column;
        gap: 1rem;
      }
    }
    @media (prefers-reduced-motion: reduce) {
      .lng-da-btn,
      .lng-da-cta,
      .lng-da-jump-link { transition: none; }
    }
  </style>
</Layout>
