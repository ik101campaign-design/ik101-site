---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
---
<Layout title="آئی کے ۱۰۱ | IK101 (Urdu)">
  <SiteNav current="/urdu" />

  <main class="lng-ur-main" dir="rtl" lang="ur">

    <!-- ═══ HERO ═══ -->
    <section class="lng-ur-hero">
      <p class="lng-ur-eyebrow">IK101</p>
      <h1 class="lng-ur-h1">عمران خان کی میراث سے آپ کے عمل تک</h1>
      <h3 class="lng-ur-subhead">
        آئ کے ۱۰۱ عوام کا ایک اقدام ہے جو عمران خان کی مضبوط، متحد پاکستان کی جدوجہد کی نمائندگی کرتا ہے اور سب کو دعوت دیتا ہے کہ وہ ملک کے مستقبل کی اجتماعی تشکیل کے لیے تحریک میں شامل ہوں اور "ترقی کے 101 منفرد منصوبے" شئیر کریں ۔
      </h3>
      <h2 class="lng-ur-hero-h2">ترقی پسند پاکستان کے لیے 101 اقدامات</h2>

      <!-- Quick-jump anchors -->
      <div class="lng-ur-anchors">
        <a class="lng-ur-anchor-btn" href="#urdu-amb">آئ کے ۱۰۱ سفیر</a>
        <a class="lng-ur-anchor-btn" href="#urdu-artist">آرٹسٹ</a>
        <a class="lng-ur-anchor-btn" href="#urdu-vol">رضاکار</a>
      </div>
    </section>

    <!-- ═══ RESOURCE QUICK LINKS ═══ -->
    <section class="lng-ur-resources">
      <div class="lng-ur-resources-grid">
        <a class="lng-ur-res-chip" href="https://drive.google.com/drive/folders/1U-Hio0z8I7dBizlwHgXtVcZM2jLeFCjj" target="_blank" rel="noopener">پوسٹ کارڈ</a>
        <a class="lng-ur-res-chip" href="https://drive.google.com/drive/folders/1DI89clL2RyHBQMP-ttzPDIMkVv0PATh8" target="_blank" rel="noopener">پٹیشنز</a>
        <a class="lng-ur-res-chip" href="https://drive.google.com/drive/folders/19sCV_szcgj98W98Kk7HI9XcjgLPikGLR" target="_blank" rel="noopener">معلوماتی فلائر</a>
        <a class="lng-ur-res-chip" href="https://drive.google.com/drive/folders/1SG9XBBLVZOWCMpA94GON1lXJLjZhDtup" target="_blank" rel="noopener">AI 4 IK101</a>
        <a class="lng-ur-res-chip" href="https://drive.google.com/drive/folders/1a2c0ytJWwS6TrfBuLLfH1DeQUCcRBFio" target="_blank" rel="noopener">ڈیجیٹل گیلری</a>
        <a class="lng-ur-res-chip" href="https://www.youtube.com/@truth2powerhub" target="_blank" rel="noopener">Truth 2 Power Hub</a>
      </div>
    </section>

    <!-- ═══ 101 SPARKS / CORE SPIRIT ═══ -->
    <section class="lng-ur-spirit">
      <h2 class="lng-ur-section-h2">آئی کے ۱۰۱ کی بنیادی روح</h2>

      <div class="lng-ur-spirit-body">
        <div class="lng-ur-spirit-img-wrap">
          <img
            class="lng-ur-spirit-img"
            src="/urdu/101-sparks-ur-mnl3wxg0OjU9J7JP.png"
            alt="آئی کے ۱۰۱ کے ۱۰۱ اقدامات"
            loading="lazy"
          />
        </div>
        <div class="lng-ur-spirit-text">
          <p>
            آئی کے ۱۰۱ کے مرکز میں عمران خان کی پائیدار میراث گونجتی ہے ـ ایک زندگی جو انہوں نے وقف کی اور گزاری ہے ایک فلاحی ریاست کی تلاش میں ـ ایک ایسی ریاست جہاں ہر فرد کے حقوق کو نہ صرف تسلیم کیا جائے بلکہ سختی سے ان حقوق کی حفاظت بھی کی جائے ۔
          </p>
          <p>
            آئی کے ۱۰۱ صرف ایک تحریک نہیں ہے بلکہ یہ آواز بلند کرنے کی، ایک عالمی سطح پر شہریوں کو یکجا کرنے کی اور ایک سچے آزاد جمہوری اور ترقی پسند پاکستان کی تعمیر میں شرکت کرنے کی بھرپور دعوت ہے ۔
          </p>
          <p>
            آئی کے ۱۰۱ کا حصہ بننے کے لیے ایک ہی جگہ موجود ہونا ضروری نہیں ہے۔ اس متحرک دائرے میں داخل ہوں، ہماری ڈیجیٹل گیلری میں اضافہ کریں، اپنے حکایات اور خصائص کو سب کے ساتھ بانٹیں اور اس طاقت کے ذریعے ایک مشترکہ آواز اٹھائیں ۔
          </p>
        </div>
      </div>
    </section>

    <!-- ═══ JOIN THE JOURNEY ═══ -->
    <section class="lng-ur-join">
      <h2 class="lng-ur-section-h2">تبدیلی کے سفر میں ہمارے ساتھ شامل ہوں!</h2>
      <p class="lng-ur-join-p">
        آپ کا عزم، ہر قدم، ہر گفتگو اہمیت رکھتی ہے۔ آئیے مل کر ایک متحد، مضبوط اور حقیقتًا آزاد پاکستان کی جدوجہد کو آگے بڑھائیں ۔
      </p>
    </section>

    <!-- ═══ AMBASSADOR ═══ -->
    <section class="lng-ur-block" id="urdu-amb">
      <h2 class="lng-ur-block-h2">آئ کے ۱۰۱ کے سفیر بنیں</h2>
      <p class="lng-ur-block-lead">
        کیا آپ پاکستان کے نظام میں تبدیلی لانے کے لیے تیار ہیں؟ تو آئیۓ آئی کے ۱۰۱ تحریک میں شامل ہو کر نظام میں مثبت تبدیلی کی کاوشوں میں اپنا حصہ ڈالیں ۔
      </p>

      <!-- Sub-action 1: Postcard -->
      <div class="lng-ur-row">
        <div class="lng-ur-row__img-wrap">
          <img
            class="lng-ur-row__img"
            src="/urdu/slider-mail-a-postcard-ur-mxBrg6oGbRc3w74P.png"
            alt="پوسٹ کارڈ بھیجیں"
            loading="lazy"
          />
        </div>
        <div class="lng-ur-row__body">
          <h6 class="lng-ur-sub-h6">پوسٹ کارڈ بھیجیں</h6>
          <p class="lng-ur-row__text">
            ایک متحرک پوسٹ کارڈ کے ذریعے ایک مثبت تبدیلی کی طرف گفتگو کا آغاز کریں۔ آئی کے ۱۰۱ کی ویب سائٹ سے اپنا پسندیدہ پوسٹ کارڈ جس زبان میں چاہیں ڈاؤن لوڈ اور پرنٹ کریں۔ پوسٹ کارڈ پر عمران خان کی کسی ایسی کامیابی کو اجاگر کریں جس نے آپ کو متاثر کیا ہو۔ ساتھ ہی ترقی کے لیے آپ اپنا کوئی انوکھا خیال بھی بتائیۓ۔ اور ان پوسٹ کارڈ کے ذریعے اپنا پیغام معاشرے کے با اثر افراد، ہر گھر، ہر گلی اور عام عوام تک پہنچائیں ۔
          </p>
          <a
            class="lng-ur-pill"
            href="https://drive.google.com/drive/folders/1U-Hio0z8I7dBizlwHgXtVcZM2jLeFCjj"
            target="_blank"
            rel="noopener"
          >پوسٹ کارڈ حاصل کریں</a>
        </div>
      </div>

      <!-- Sub-action 2: Appeal / Petition -->
      <div class="lng-ur-row lng-ur-row--flip">
        <div class="lng-ur-row__img-wrap">
          <img
            class="lng-ur-row__img"
            src="/urdu/slider-sign-a-petition-ur-YZ9236BLxpceJ87Z.png"
            alt="منفی اقدامات کے خلاف اپیل"
            loading="lazy"
          />
        </div>
        <div class="lng-ur-row__body">
          <h6 class="lng-ur-sub-h6">منفی اقدامات کے خلاف اپیل کریں</h6>
          <p class="lng-ur-row__text">
            اپنی اجتماعی طاقت کو استعمال کیجیے ۔ ہزاروں دستخط کی ہوئی عرض داشتوں کو طاقتور حلقوں یعنی بڑے سیاست دانوں، بڑے بڑے تجارتی اداروں اور سفیروں کو بھیجیں ۔ اور انکی توجہ اُن بہیمانہ کاروائیوں کی طرف مبذول کروائیں جو دنیا کی چھٹی بڑی سیاسی جماعت کے ساتھ کیا جا رہا ہے اور جو پاکستان کے سب سے مقبول لیڈر کو غیر قانونی طریقے سے جیل میں بند کیے ہوئے ہیں۔
          </p>
          <a
            class="lng-ur-pill"
            href="https://drive.google.com/drive/folders/1DI89clL2RyHBQMP-ttzPDIMkVv0PATh8"
            target="_blank"
            rel="noopener"
          >پٹیشنز پہ دستخط</a>
        </div>
      </div>

      <!-- Sub-action 3: Amplify -->
      <div class="lng-ur-row">
        <div class="lng-ur-row__img-wrap">
          <img
            class="lng-ur-row__img"
            src="/urdu/slider-amplify-online-ur-AE0pb8Q9gXSqEEXD.png"
            alt="ہماری آواز کو وسعت دیں"
            loading="lazy"
          />
        </div>
        <div class="lng-ur-row__body">
          <h6 class="lng-ur-sub-h6">ہماری آواز کو وسعت دیں</h6>
          <p class="lng-ur-row__text">
            اکّا دکّا صدا یا آواز بے اثر ہوتی ہے۔ اجتماعی آوازوں کی گرج سے بڑے سے بڑے ایوان لرز جاتے ہیں۔ گھر گھر جا کر مثبت قیادت اور تبدیلی کا پیغام پھیلائیں۔ انٹرنیٹ کے ذریعے اپنے احساسات، خیالات اور جذبات کو دنیا کے گوشے گوشے میں پہنچائیں۔ ہیش ٹیگ IK101 # پر جا کر اپنے ہم خیالوں سے مل کر اپنی اجتماعی آواز سے ظلم کے ایوانوں کو روئی کے گالوں کی طرح اڑا دیں۔
          </p>
          <a
            class="lng-ur-pill"
            href="https://drive.google.com/drive/folders/1a2c0ytJWwS6TrfBuLLfH1DeQUCcRBFio"
            target="_blank"
            rel="noopener"
          >ڈیجیٹل گیلری</a>
        </div>
      </div>
    </section>

    <!-- ═══ ARTIST ═══ -->
    <section class="lng-ur-block" id="urdu-artist">
      <h2 class="lng-ur-block-h2">اپنے فن کو تبدیلی کی آواز بنائیں</h2>

      <div class="lng-ur-row lng-ur-row--flip">
        <div class="lng-ur-row__img-wrap">
          <img
            class="lng-ur-row__img"
            src="/urdu/art-for-postcard-urdu-YKbJXvnj3xfGR3RW.png"
            alt="اردو پوسٹ کارڈ کے لیے فن پارہ"
            loading="lazy"
          />
        </div>
        <div class="lng-ur-row__body">
          <p class="lng-ur-row__text">
            آپ کے کینوس تبدیلی کا مطالبہ کر رہے ہیں! اپنے فن سے جمہوریت، انسانی حقوق کی بحالی اور عمران خان کے مقصد کو آگے بڑھائیے۔ آپ کی تخلیقی صلاحیت مثبت مقاصد کے حصول میں نمایاں کردار ادا کر سکتی ہے۔
          </p>
          <p class="lng-ur-row__text">
            آئی کے ۱۰۱ کیمپین میں اپنے فن پاروں کے ساتھ شرکت کریں اور ایک بصری انقلاب کا حصہ بنیے۔ آپ کا فن پارہ عالمی پوسٹ کارڈ اور ڈیجیٹل پلیٹ فارمز پہ نمایاں کیا جائے گا تاکہ جمہوریت اور انسانی حقوق کا پیغام گھر گھر پھیل سکے ۔
          </p>
          <div class="lng-ur-cta-row">
            <a
              class="lng-ur-pill"
              href="https://drive.google.com/drive/folders/1qpAxa80_9z03Q6vyzGRJFWO4qHtNtT24"
              target="_blank"
              rel="noopener"
            >آرٹسٹ کال</a>
            <a
              class="lng-ur-pill lng-ur-pill--outline"
              href="https://docs.google.com/forms/d/e/1FAIpQLScp3ky9BpBUM6DvEQssAeDiVJEvlNFmRbzeR8mxSSFng5_4yQ/viewform"
              target="_blank"
              rel="noopener"
            >فن پارہ جمع کرائیں</a>
            <a
              class="lng-ur-pill lng-ur-pill--outline"
              href="https://drive.google.com/drive/folders/1aK4u7ohzy-2qYrll0n39q-cKwwpFnqmj"
              target="_blank"
              rel="noopener"
            >تصورات</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ VOLUNTEER ═══ -->
    <section class="lng-ur-block" id="urdu-vol">
      <h2 class="lng-ur-block-h2">رضاکار کے طور پر رجسٹر ہوں</h2>

      <div class="lng-ur-row">
        <div class="lng-ur-row__img-wrap">
          <img
            class="lng-ur-row__img"
            src="/urdu/ik101-student---1-d95pL2wNZBTvbDQo.png"
            alt="آئی کے ۱۰۱ رضاکار"
            loading="lazy"
          />
        </div>
        <div class="lng-ur-row__body">
          <p class="lng-ur-row__text">
            اپنی انفرادی صلاحیتوں کا بھرپور استعمال کرنے کے لیے اپنی رضاکارانہ خدمات پیش کیجئے۔ اس ضمن میں آئی کے ۱۰۱ سے رابطہ کیجئے تاکہ اپ کی خداداد صلاحیتیں ملک اور قوم کے لیے استعمال کی جا سکیں ۔
          </p>
          <a
            class="lng-ur-pill"
            href="https://docs.google.com/forms/d/e/1FAIpQLSdOwDOVHxvIIrH_HKSXcstQbiW_ibtkKkk_5q-zt2is7H1ulQ/viewform"
            target="_blank"
            rel="noopener"
          >رضاکاررجسٹریشن فارم</a>
        </div>
      </div>
    </section>

    <!-- ═══ CLOSING ═══ -->
    <section class="lng-ur-close">
      <h4 class="lng-ur-close-h4">
        آئیے ہم اپنی اجتماعی آواز دنیا کو سنائیں اور ایک حقیقی جمہوری پاکستان کو تشکیل دیں
      </h4>
      <h3 class="lng-ur-tagline">My Voice, My Pakistan, My Movement.</h3>
    </section>

  </main>

  <!-- FOOTER — LTR intentionally (English nav labels) -->
  <footer class="lng-ur-foot">
    <nav class="lng-ur-foot-nav">
      <a href="/">Resources</a>
      <a href="/connect">Connect</a>
      <a href="/useful-links">Useful Links</a>
    </nav>
    <p class="lng-ur-foot-copy">IK101 &copy; 2023</p>
  </footer>

  <style is:global>
    /* ══════════════════════════════════════════════════════
       Urdu landing page — all classes prefixed .lng-ur-
       RTL layout; Urdu-optimised line-height + text-align
    ══════════════════════════════════════════════════════ */

    /* BASE */
    .lng-ur-main {
      max-width: 1200px;
      margin: 0 auto;
      padding: clamp(2rem, 5vw, 4rem) 1.25rem 2rem;
      font-family: 'Hanken Grotesk', 'Noto Nastaliq Urdu', sans-serif;
      color: var(--ink);
    }
    .lng-ur-main p,
    .lng-ur-main h1,
    .lng-ur-main h2,
    .lng-ur-main h3,
    .lng-ur-main h4,
    .lng-ur-main h6,
    .lng-ur-main li {
      text-align: right;
      line-height: 1.9;
    }

    /* ── HERO ── */
    .lng-ur-hero {
      text-align: right;
      max-width: 780px;
      margin: 0 0 clamp(3rem, 8vw, 5rem);
    }
    .lng-ur-eyebrow {
      color: var(--accent);
      font-weight: 600;
      letter-spacing: .14em;
      text-transform: uppercase;
      font-size: .8rem;
      margin: 0 0 1rem;
      text-align: right;
    }
    .lng-ur-h1 {
      font-size: clamp(2.2rem, 5vw, 3.8rem);
      font-weight: 700;
      letter-spacing: -.025em;
      line-height: 1.25;
      margin: 0 0 1.2rem;
      color: var(--ink);
    }
    .lng-ur-subhead {
      font-size: clamp(1rem, 2vw, 1.2rem);
      font-weight: 400;
      color: var(--muted);
      line-height: 1.9;
      margin: 0 0 1.4rem;
    }
    .lng-ur-hero-h2 {
      font-size: clamp(1.4rem, 3vw, 2rem);
      font-weight: 700;
      color: var(--ink);
      margin: 0 0 2rem;
      letter-spacing: -.02em;
    }

    /* anchor buttons */
    .lng-ur-anchors {
      display: flex;
      flex-wrap: wrap;
      gap: .75rem;
      justify-content: flex-end;
    }
    .lng-ur-anchor-btn {
      display: inline-block;
      font-size: .9rem;
      font-weight: 600;
      color: var(--ink);
      text-decoration: none;
      padding: .6rem 1.4rem;
      border: 1.5px solid var(--ink);
      border-radius: 100px;
      transition: background .18s var(--ease-out), color .18s;
    }
    .lng-ur-anchor-btn:hover {
      background: var(--ink);
      color: #fff;
    }

    /* ── RESOURCE CHIPS ── */
    .lng-ur-resources {
      margin-bottom: clamp(3rem, 8vw, 5rem);
    }
    .lng-ur-resources-grid {
      display: flex;
      flex-wrap: wrap;
      gap: .65rem;
      justify-content: flex-end;
    }
    .lng-ur-res-chip {
      display: inline-block;
      font-size: .85rem;
      font-weight: 500;
      color: var(--accent);
      text-decoration: none;
      padding: .45rem 1.1rem;
      border: 1.5px solid var(--accent);
      border-radius: 100px;
      background: var(--accent-soft, rgba(0,191,99,.07));
      transition: background .18s, color .18s;
    }
    .lng-ur-res-chip:hover {
      background: var(--accent);
      color: #fff;
    }

    /* ── SECTION HEADINGS ── */
    .lng-ur-section-h2 {
      font-size: clamp(1.6rem, 3.5vw, 2.4rem);
      font-weight: 700;
      letter-spacing: -.02em;
      margin: 0 0 1.6rem;
      color: var(--ink);
      text-align: right;
    }

    /* ── SPIRIT SECTION ── */
    .lng-ur-spirit {
      margin-bottom: clamp(3.5rem, 9vw, 6rem);
      border-top: 1px solid var(--faint);
      padding-top: clamp(2.5rem, 6vw, 4.5rem);
    }
    .lng-ur-spirit-body {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: clamp(2rem, 5vw, 4rem);
      align-items: center;
      /* image on left, text on right — natural RTL order */
    }
    .lng-ur-spirit-img-wrap {
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 20px 56px rgba(20, 40, 28, .12);
      aspect-ratio: 4 / 3;
      background: var(--faint);
      order: 1;
    }
    .lng-ur-spirit-text {
      order: 2;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .lng-ur-spirit-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .lng-ur-spirit-text p {
      color: var(--muted);
      font-size: 1rem;
      margin: 0;
    }

    /* ── JOIN SECTION ── */
    .lng-ur-join {
      margin-bottom: clamp(3.5rem, 9vw, 6rem);
      background: var(--accent-soft, rgba(0,191,99,.07));
      border-radius: 16px;
      padding: clamp(2rem, 5vw, 3.5rem);
      border: 1px solid rgba(0,191,99,.18);
    }
    .lng-ur-join .lng-ur-section-h2 {
      color: var(--ink);
    }
    .lng-ur-join-p {
      color: var(--muted);
      font-size: 1.05rem;
      margin: 0;
    }

    /* ── BLOCK SECTIONS (Ambassador / Artist / Volunteer) ── */
    .lng-ur-block {
      border-top: 1px solid var(--faint);
      padding-top: clamp(2.5rem, 6vw, 4.5rem);
      margin-bottom: clamp(3.5rem, 9vw, 6rem);
    }
    .lng-ur-block-h2 {
      font-size: clamp(1.6rem, 3.5vw, 2.4rem);
      font-weight: 700;
      letter-spacing: -.02em;
      margin: 0 0 .5rem;
      color: var(--accent);
      text-align: right;
    }
    .lng-ur-block-lead {
      color: var(--muted);
      font-size: 1.05rem;
      line-height: 1.9;
      margin: 0 0 clamp(2rem, 5vw, 3.5rem);
      text-align: right;
    }

    /* ── ROWS (image + text pairs) ── */
    .lng-ur-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: clamp(2rem, 5vw, 4rem);
      align-items: center;
      margin-bottom: clamp(2.5rem, 7vw, 5rem);
    }
    /* flip: text side first visually, image second — in RTL grid */
    .lng-ur-row--flip {
      /* In RTL context, reversing column order makes image appear on right */
      direction: ltr;
    }
    .lng-ur-row--flip > * {
      direction: rtl;
    }
    .lng-ur-row__img-wrap {
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 20px 56px rgba(20, 40, 28, .12);
      aspect-ratio: 4 / 3;
      background: var(--faint);
    }
    .lng-ur-row__img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .lng-ur-row__body {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      text-align: right;
    }
    .lng-ur-sub-h6 {
      font-size: clamp(1.1rem, 2.2vw, 1.5rem);
      font-weight: 700;
      color: var(--ink);
      margin: 0;
      letter-spacing: -.015em;
    }
    .lng-ur-row__text {
      color: var(--muted);
      font-size: 1rem;
      line-height: 1.9;
      margin: 0;
    }

    /* ── CTA PILLS ── */
    .lng-ur-pill {
      display: inline-block;
      font-weight: 600;
      font-size: .95rem;
      text-decoration: none;
      padding: .75rem 1.65rem;
      border-radius: 100px;
      background: var(--accent);
      color: var(--ink);
      border: 1.5px solid var(--accent);
      transition: filter .18s var(--ease-out), transform .18s var(--ease-out);
      align-self: flex-end;
    }
    .lng-ur-pill:hover {
      filter: brightness(1.07);
      transform: translateY(-1px);
    }
    .lng-ur-pill--outline {
      background: transparent;
      color: var(--ink);
      border-color: var(--ink);
    }
    .lng-ur-pill--outline:hover {
      background: var(--faint);
      filter: none;
    }
    .lng-ur-cta-row {
      display: flex;
      flex-wrap: wrap;
      gap: .75rem;
      justify-content: flex-end;
    }

    /* ── CLOSING ── */
    .lng-ur-close {
      text-align: center;
      border-top: 1px solid var(--faint);
      padding-top: clamp(3rem, 8vw, 5.5rem);
      margin-top: clamp(2rem, 6vw, 4rem);
    }
    .lng-ur-close-h4 {
      font-size: clamp(1.3rem, 3vw, 2rem);
      font-weight: 700;
      letter-spacing: -.02em;
      color: var(--ink);
      max-width: 700px;
      margin: 0 auto 1.5rem;
      line-height: 1.7;
    }
    .lng-ur-tagline {
      font-size: clamp(1.4rem, 3.5vw, 2.2rem);
      font-weight: 700;
      color: var(--accent);
      margin: 0;
      /* tagline stays LTR — it's English */
      direction: ltr;
      unicode-bidi: embed;
    }

    /* ── FOOTER ── */
    .lng-ur-foot {
      border-top: 1px solid var(--faint);
      margin-top: clamp(3rem, 8vw, 5rem);
      padding: 2.5rem 1.25rem;
      text-align: center;
      direction: ltr;
    }
    .lng-ur-foot-nav {
      display: flex;
      gap: 2rem;
      justify-content: center;
      margin-bottom: 1.2rem;
    }
    .lng-ur-foot-nav a {
      color: var(--muted);
      text-decoration: none;
      font-size: .9rem;
      transition: color .18s;
    }
    .lng-ur-foot-nav a:hover {
      color: var(--ink);
    }
    .lng-ur-foot-copy {
      color: var(--muted);
      font-size: .8rem;
      margin: 0;
    }

    /* ══ RESPONSIVE ══ */
    @media (max-width: 720px) {
      .lng-ur-spirit-body {
        grid-template-columns: 1fr;
      }
      .lng-ur-spirit-img-wrap {
        order: 0;
        aspect-ratio: 16 / 10;
      }
      .lng-ur-spirit-text {
        order: 1;
      }

      .lng-ur-row,
      .lng-ur-row--flip {
        grid-template-columns: 1fr;
        direction: rtl;
      }
      .lng-ur-row--flip > * {
        direction: rtl;
      }
      .lng-ur-row__img-wrap {
        aspect-ratio: 16 / 10;
      }
      .lng-ur-pill {
        align-self: stretch;
        text-align: center;
      }
      .lng-ur-cta-row {
        justify-content: center;
      }
      .lng-ur-anchors {
        justify-content: center;
      }
      .lng-ur-resources-grid {
        justify-content: center;
      }
    }
  </style>
</Layout>
