---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
---
<Layout title="Spirit of IK101 | IK101">
  <SiteNav current="/spirit-of-ik101" />

  <main class="spt-main">

    <!-- ── HERO ── -->
    <section class="spt-hero">
      <p class="spt-eyebrow">Spirit of IK101</p>
      <h1 class="spt-title">Not just a movement, IK101 is a call to action.</h1>
      <p class="spt-lede">At the heart of IK101 resonates the enduring legacy of Imran Khan — a life dedicated to the pursuit of a welfare state where every individual's rights are not merely acknowledged but fiercely protected. IK101 is a call to amplify your voice, connect with citizens globally, and contribute to building a truly independent, democratic, and progressive Pakistan.</p>
    </section>

    <!-- ── SECTION 1: Grassroots Activation (postcard image left) ── -->
    <section class="spt-row">
      <div class="spt-row__img-wrap">
        <img
          class="spt-row__img"
          src="/spirit/mail-ik101-postcard-mjE2o70jyaIV6QJg.png"
          alt="IK101 postcard — Grassroots Activation"
          loading="lazy"
        />
      </div>
      <div class="spt-row__body">
        <p class="spt-row__label">Grassroots Activation</p>
        <h2 class="spt-row__heading">Join the movement!</h2>
        <p class="spt-row__text">You don't have to be in one place to be part of IK101. Jump into the action from grassroots engagement to the dynamic stage of IK101 Engage, a platform where your ideas for progress take life. Enrich our digital gallery, share your narratives and inspirations, and let's showcase the power of collective voices.</p>
        <p class="spt-row__text">Join us on a journey of grassroots change! Become an #IK101 ambassador, undertake door-to-door campaign and spread the message of positive leadership and change. Every step, every conversation matters. Print, write, share.</p>
        <a class="spt-row__cta" href="/postcards">Grassroots Activation &#8594;</a>
      </div>
    </section>

    <!-- ── SECTION 2: IK101 Engage (engage image right) ── -->
    <section class="spt-row spt-row--flip">
      <div class="spt-row__img-wrap">
        <img
          class="spt-row__img"
          src="/spirit/ik101-engage-m7Vpe1BgQMS7r7G1.png"
          alt="IK101 Engage platform"
          loading="lazy"
        />
      </div>
      <div class="spt-row__body">
        <p class="spt-row__label">Coming Soon</p>
        <h2 class="spt-row__heading">Engage (Coming Soon)</h2>
        <p class="spt-row__text">IK101 Engage serves as a conduit linking global citizens to local visionaries committed to progress. Within this dynamic forum, dedicated Pakistanis find a stage to voice real community issues, discuss innovative solutions, and collaborate with a global audience to transform ideas into reality.</p>
        <a class="spt-row__cta spt-row__cta--muted" href="/spirit-of-ik101" aria-disabled="true">Coming Soon</a>
      </div>
    </section>

    <!-- ── SECTION 3: Truth To Power Hub (logo left) ── -->
    <section class="spt-row">
      <div class="spt-row__img-wrap">
        <img
          class="spt-row__img spt-row__img--contain"
          src="/spirit/logo---truth2power-AVLJeDGEKrTKplwR.png"
          alt="Truth To Power Hub logo"
          loading="lazy"
        />
      </div>
      <div class="spt-row__body">
        <p class="spt-row__label">Truth To Power Hub</p>
        <h2 class="spt-row__heading">Building a community of trust through truth-telling.</h2>
        <p class="spt-row__text">At IK101, we're building a community of trust through truth-telling. For every fake narrative, we promise 101 voices of truth. Join us in peaceful resistance as we build a digital archive of real stories, resilience and hope. Let's write our own history. If we don't, it will be written for us.</p>
        <a class="spt-row__cta" href="https://www.youtube.com/@truth2powerhub" target="_blank" rel="noopener">Truth To Power Hub &#8594;</a>
      </div>
    </section>

    <!-- ── DIVIDER HEADING ── -->
    <div class="spt-mid-heading">
      <h2 class="spt-mid-h2">Let the world hear our collective voice, as we shape the narrative for a truly democratic Pakistan.</h2>
    </div>

    <!-- ── SECTION 4: Azad Pakistan (image right) ── -->
    <section class="spt-row spt-row--flip">
      <div class="spt-row__img-wrap">
        <img
          class="spt-row__img"
          src="/spirit/myazadpak_website-mnl98wnqGQiGQbGe.png"
          alt="My Azad Pakistan — Haqiqi Azadi"
          loading="lazy"
        />
      </div>
      <div class="spt-row__body">
        <p class="spt-row__label">Azad Pakistan</p>
        <h2 class="spt-row__heading">In my truly independent Pakistan&hellip;</h2>
        <p class="spt-row__text">This phrase represents the beginning of a powerful dialogue, where every Pakistani can contribute their vision of what true independence means to them. Whether it's about justice, equality, education, or governance, we want to know: How do you picture Haqiqi Azadi?</p>
        <a class="spt-row__cta" href="https://drive.google.com/drive/folders/1y1wcxBcLuSPnApMP8oB-Bch9xHGqdhRs?usp=sharing" target="_blank" rel="noopener">Azad Pakistan &#8594;</a>
      </div>
    </section>

    <!-- ── SECTION 5: SOS Capt. Gulsher (image left) ── -->
    <section class="spt-row">
      <div class="spt-row__img-wrap">
        <img
          class="spt-row__img"
          src="/spirit/sos---capt-gulsher-m7VKvOV2GniLR5oq.png"
          alt="SOS Captain Gulsher — voice of the masses"
          loading="lazy"
        />
      </div>
      <div class="spt-row__body">
        <p class="spt-row__label">SOS CAPT. GULSHER</p>
        <h2 class="spt-row__heading">The voice of the masses.</h2>
        <p class="spt-row__text">As Pakistan faced the aftermath of a regime change, Captain Gulsher, character of a young army officer known from the 90s Pakistani drama serial Sunehray Din, became the voice of the masses and a conduit between them and the ruling quarters. This powerful social media response relayed public reactions to the evolving situation post April 9th, 2022 regime change operation in Pakistan; and served as a rallying cry for true freedom.</p>
        <a class="spt-row__cta" href="https://youtube.com/playlist?list=PLo91venkyugDJV90LZw4VLiQyN3QhAxNL&si=KhSMgN_gnF_rBqkr" target="_blank" rel="noopener">SOS CAPT. GULSHER &#8594;</a>
      </div>
    </section>

    <!-- ── SECTION 6: Symbols of Democracy (image right) ── -->
    <section class="spt-row spt-row--flip">
      <div class="spt-row__img-wrap">
        <img
          class="spt-row__img"
          src="/spirit/symbols-of-democracy-mePnE7ORO4Feb540.png"
          alt="Symbols of Democracy — 2024 elections"
          loading="lazy"
        />
      </div>
      <div class="spt-row__body">
        <p class="spt-row__label">Symbols of Democracy</p>
        <h2 class="spt-row__heading">Turning symbols into a voice for democracy.</h2>
        <p class="spt-row__text">When the fascist regime in Pakistan tried to sabotage the 2024 general elections by taking away largest political party's election symbol (cricket bat), the IK101 Ambassadors sprang into action. They turned to social media and AI to creatively highlight each candidate's new symbol — from fruits and vegetables to everyday items — ensuring voters could still identify and support their preferred candidates.</p>
        <a class="spt-row__cta" href="https://youtube.com/playlist?list=PLo91venkyugCHT44o-5zCIWY1Ba62JBOo&feature=shared" target="_blank" rel="noopener">Symbols of Democracy &#8594;</a>
      </div>
    </section>

    <!-- ── CLOSING STATEMENT ── -->
    <section class="spt-close">
      <p class="spt-statement">My Voice, My Pakistan, My Movement.</p>
    </section>

  </main>

  <footer class="spt-foot">
    <nav class="spt-foot-links">
      <a href="/#resources">Resources</a>
      <a href="/connect">Connect</a>
      <a href="/useful-links">Useful Links</a>
    </nav>
    <p class="spt-foot-copy">IK101 &copy; 2023</p>
  </footer>

  <style is:global>
    /* ── Spirit of IK101 — all classes prefixed .spt- ── */

    .spt-main {
      max-width: 1200px;
      margin: 0 auto;
      padding: clamp(2rem, 5vw, 4rem) 1.25rem 2rem;
    }

    /* HERO */
    .spt-hero {
      text-align: center;
      max-width: 66ch;
      margin: 0 auto clamp(3.5rem, 8vw, 6rem);
    }
    .spt-eyebrow {
      color: var(--accent);
      font-weight: 600;
      letter-spacing: .14em;
      text-transform: uppercase;
      font-size: .8rem;
      margin: 0 0 1rem;
    }
    .spt-title {
      font-size: clamp(2rem, 4.6vw, 3.4rem);
      line-height: 1.06;
      letter-spacing: -.025em;
      font-weight: 700;
      margin: 0 auto 1.1rem;
      max-width: 22ch;
    }
    .spt-lede {
      color: var(--muted);
      font-size: 1.05rem;
      line-height: 1.62;
      max-width: 60ch;
      margin: 0 auto;
    }

    /* FEATURE ROWS */
    .spt-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: clamp(2rem, 5vw, 4.5rem);
      align-items: center;
      margin-bottom: clamp(3rem, 8vw, 6rem);
    }
    .spt-row--flip {
      direction: rtl;
    }
    .spt-row--flip > * {
      direction: ltr;
    }
    .spt-row__img-wrap {
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 20px 56px rgba(20, 40, 28, .13);
      aspect-ratio: 4 / 3;
      background: #f1f5f2;
    }
    .spt-row__img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .spt-row__img--contain {
      object-fit: contain;
      padding: 1.5rem;
    }
    .spt-row__body {
      display: flex;
      flex-direction: column;
      gap: .9rem;
    }
    .spt-row__label {
      color: var(--accent);
      font-weight: 600;
      letter-spacing: .1em;
      text-transform: uppercase;
      font-size: .78rem;
      margin: 0;
    }
    .spt-row__heading {
      font-size: clamp(1.4rem, 2.6vw, 2rem);
      font-weight: 700;
      letter-spacing: -.02em;
      line-height: 1.15;
      margin: 0;
    }
    .spt-row__text {
      color: var(--muted);
      font-size: 1rem;
      line-height: 1.65;
      margin: 0;
    }
    .spt-row__cta {
      display: inline-block;
      color: var(--accent);
      font-weight: 600;
      font-size: .95rem;
      text-decoration: none;
      padding: .7rem 1.5rem;
      border: 1.5px solid var(--accent);
      border-radius: 100px;
      align-self: flex-start;
      transition: background .2s var(--ease-out), color .2s, transform .2s var(--ease-out);
    }
    .spt-row__cta:hover {
      background: var(--accent);
      color: var(--ink);
      transform: translateY(-1px);
    }
    .spt-row__cta--muted {
      color: var(--muted);
      border-color: var(--faint);
      pointer-events: none;
      opacity: .65;
    }

    /* MID HEADING */
    .spt-mid-heading {
      border-top: 1px solid var(--faint);
      border-bottom: 1px solid var(--faint);
      padding: clamp(2rem, 5vw, 3.5rem) 1rem;
      margin: 0 0 clamp(3rem, 8vw, 6rem);
      text-align: center;
    }
    .spt-mid-h2 {
      font-size: clamp(1.3rem, 2.8vw, 2rem);
      font-weight: 700;
      letter-spacing: -.02em;
      line-height: 1.22;
      max-width: 48ch;
      margin: 0 auto;
      color: var(--ink);
    }

    /* CLOSING STATEMENT */
    .spt-close {
      margin-top: clamp(4rem, 10vw, 7rem);
      text-align: center;
    }
    .spt-statement {
      font-size: clamp(1.6rem, 4vw, 2.6rem);
      font-weight: 700;
      letter-spacing: -.02em;
      margin: 0;
    }

    /* FOOTER */
    .spt-foot {
      border-top: 1px solid var(--faint);
      margin-top: clamp(3rem, 8vw, 6rem);
      padding: 3rem 1.25rem;
      text-align: center;
    }
    .spt-foot-links {
      display: flex;
      gap: 2rem;
      justify-content: center;
      margin-bottom: 1.5rem;
    }
    .spt-foot-links a {
      color: var(--muted);
      text-decoration: none;
      font-size: .9rem;
    }
    .spt-foot-links a:hover {
      color: var(--ink);
    }
    .spt-foot-copy {
      color: var(--muted);
      font-size: .8rem;
      margin: 0;
    }

    /* RESPONSIVE */
    @media (max-width: 720px) {
      .spt-row,
      .spt-row--flip {
        grid-template-columns: 1fr;
        direction: ltr;
      }
      .spt-row--flip > * {
        direction: ltr;
      }
      .spt-row__img-wrap {
        aspect-ratio: 16 / 10;
      }
      .spt-row__cta {
        align-self: stretch;
        text-align: center;
      }
    }
    @media (prefers-reduced-motion: reduce) {
      .spt-row__cta { transition: none; }
    }
  </style>
</Layout>
